<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/resycleview"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:background="#FAF7F7"
    android:backgroundTint="#FDFDF7"
    android:backgroundTintMode="add"
    android:foregroundTint="#F6F6F4">

    <Button
        android:id="@+id/btnRaceNameForImport"
        android:layout_width="395dp"
        android:layout_height="45dp"
        android:background="@drawable/zinukpage_customer"
        android:drawableTint="#F8F5F5"
        android:gravity="center"
        android:textSize="15dp"
        android:text="Button"
        android:textColor="#000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.257" />

    <TextView
        android:id="@+id/textViewOwner"
        android:layout_width="47dp"
        android:layout_height="25dp"
        android:backgroundTint="#FFFFFF"
        android:text="Owner"
        android:textSize="12dp"
        android:textColor="#2196F3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/TextDateView"
        app:layout_constraintHorizontal_bias="0.269"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnRaceNameForImport"
        app:layout_constraintVertical_bias="0.0" />

    <TextView
        android:id="@+id/TextDateView"
        android:layout_width="128dp"
        android:layout_height="20dp"
        android:gravity="center"
        android:text="Date"
        android:textSize="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.971"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/btnRaceNameForImport"
        app:layout_constraintVertical_bias="0.0" />

</androidx.constraintlayout.widget.ConstraintLayout>